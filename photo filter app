   "source": [
    "import tkinter as tk\n",
    "from tkinter import filedialog, messagebox\n",
    "from PIL import Image, ImageTk, ImageFilter, ImageEnhance\n",
    "\n",
    "original_image = None\n",
    "current_image = None\n",
    "display_image = None\n",
    "\n",
    "def open_image():\n",
    "    global original_image, current_image, display_image\n",
    "\n",
    "    file_path = filedialog.askopenfilename(\n",
    "        filetypes=[(\"Image Files\", \"*.png *.jpg *.jpeg *.gif *.bmp\")]\n",
    "    )\n",
    "\n",
    "    if file_path:\n",
    "        original_image = Image.open(file_path)\n",
    "        current_image = original_image.copy()\n",
    "        show_image(current_image)\n",
    "        status_label.config(text=\"Image loaded successfully!\")\n",
    "\n",
    "def show_image(image):\n",
    "    global display_image\n",
    "\n",
    "    preview = image.copy()\n",
    "    preview.thumbnail((300, 300))\n",
    "\n",
    "    display_image = ImageTk.PhotoImage(preview)\n",
    "    image_label.config(image=display_image)\n",
    "    image_label.image = display_image\n",
    "\n",
    "def apply_grayscale():\n",
    "    global current_image\n",
    "\n",
    "    if current_image is None:\n",
    "        messagebox.showwarning(\"No Image\", \"Please open an image first.\")\n",
    "        return\n",
    "\n",
    "    current_image = current_image.convert(\"L\")\n",
    "    show_image(current_image)\n",
    "    status_label.config(text=\"Grayscale filter applied.\")\n",
    "\n",
    "def apply_blur():\n",
    "    global current_image\n",
    "\n",
    "    if current_image is None:\n",
    "        messagebox.showwarning(\"No Image\", \"Please open an image first.\")\n",
    "        return\n",
    "\n",
    "    current_image = current_image.filter(ImageFilter.BLUR)\n",
    "    show_image(current_image)\n",
    "    status_label.config(text=\"Blur filter applied.\")\n",
    "\n",
    "def increase_brightness():\n",
    "    global current_image\n",
    "\n",
    "    if current_image is None:\n",
    "        messagebox.showwarning(\"No Image\", \"Please open an image first.\")\n",
    "        return\n",
    "\n",
    "    enhancer = ImageEnhance.Brightness(current_image)\n",
    "    current_image = enhancer.enhance(1.5)\n",
    "    show_image(current_image)\n",
    "    status_label.config(text=\"Brightness increased.\")\n",
    "\n",
    "def reset_image():\n",
    "    global current_image\n",
    "\n",
    "    if original_image is None:\n",
    "        messagebox.showwarning(\"No Image\", \"Please open an image first.\")\n",
    "        return\n",
    "\n",
    "    current_image = original_image.copy()\n",
    "    show_image(current_image)\n",
    "    status_label.config(text=\"Image reset.\")\n",
    "\n",
    "def save_image():\n",
    "    if current_image is None:\n",
    "        messagebox.showwarning(\"No Image\", \"Please open an image first.\")\n",
    "        return\n",
    "\n",
    "    save_path = filedialog.asksaveasfilename(\n",
    "        defaultextension=\".png\",\n",
    "        filetypes=[(\"PNG file\", \"*.png\"), (\"JPEG file\", \"*.jpg\")]\n",
    "    )\n",
    "\n",
    "    if save_path:\n",
    "        current_image.save(save_path)\n",
    "        status_label.config(text=\"Image saved successfully!\")\n",
    "\n",
    "root = tk.Tk()\n",
    "root.title(\"Photography Filter App\")\n",
    "root.geometry(\"450x750\")\n",
    "root.configure(bg=\"#f2f2f2\")\n",
    "\n",
    "title_label = tk.Label(\n",
    "    root,\n",
    "    text=\"Photography Filter App\",\n",
    "    font=(\"Arial\", 18, \"bold\"),\n",
    "    bg=\"#f2f2f2\",\n",
    "    fg=\"#333333\"\n",
    ")\n",
    "title_label.pack(pady=10)\n",
    "\n",
    "image_label = tk.Label(root, bg=\"#d9d9d9\")\n",
    "image_label.pack(pady=10)\n",
    "\n",
    "open_button = tk.Button(root, text=\"Open Image\", command=open_image, bg=\"#4CAF50\", fg=\"white\", width=20)\n",
    "open_button.pack(pady=5)\n",
    "\n",
    "gray_button = tk.Button(root, text=\"Apply Grayscale\", command=apply_grayscale, bg=\"#555555\", fg=\"white\", width=20)\n",
    "gray_button.pack(pady=5)\n",
    "\n",
    "blur_button = tk.Button(root, text=\"Apply Blur\", command=apply_blur, bg=\"#2196F3\", fg=\"white\", width=20)\n",
    "blur_button.pack(pady=5)\n",
    "\n",
    "bright_button = tk.Button(root, text=\"Increase Brightness\", command=increase_brightness, bg=\"#FFC107\", fg=\"black\", width=20)\n",
    "bright_button.pack(pady=5)\n",
    "\n",
    "reset_button = tk.Button(root, text=\"Reset Image\", command=reset_image, bg=\"#9C27B0\", fg=\"white\", width=20)\n",
    "reset_button.pack(pady=5)\n",
    "\n",
    "save_button = tk.Button(root, text=\"Save Image\", command=save_image, bg=\"#FF5722\", fg=\"white\", width=20)\n",
    "save_button.pack(pady=5)\n",
    "\n",
    "status_label = tk.Label(root, text=\"Open an image to begin.\", bg=\"#f2f2f2\", fg=\"#333333\")\n",
    "status_label.pack(pady=10)\n",
    "\n",
    "root.mainloop()"
   ]
